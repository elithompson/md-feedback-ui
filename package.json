{
  "name": "plan-reviewer",
  "version": "0.1.0",
  "description": "Browser-based multi-file markdown review UI with inline commenting and screenshot support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elithompson/plan-reviewer.git"
  },
  "homepage": "https://github.com/elithompson/plan-reviewer",
  "bugs": {
    "url": "https://github.com/elithompson/plan-reviewer/issues"
  },
  "keywords": [
    "markdown",
    "review",
    "claude-code",
    "cli",
    "mermaid",
    "inline-comments"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "plan-reviewer": "./dist/server/index.js"
  },
  "files": [
    "dist/",
    "skill/plan-review.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "glob": "^11.0.1",
    "mermaid": "^11.13.0",
    "multer": "^2.0.1",
    "open": "^10.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.29.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
